# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
JWT_SECRET=gigashield_dev_jwt_secret_change_in_production

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=gigashield
POSTGRES_USER=gigashield
POSTGRES_PASSWORD=gigashield123
DATABASE_URL=postgresql://gigashield:gigashield123@localhost:5432/gigashield

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@localhost:6379

# ── ML Services ───────────────────────────────────────────────────────────────
SHIELD_SAC_URL=http://localhost:8001
PADS_URL=http://localhost:8002
DSI_URL=http://localhost:8003

# ── OpenWeatherMap (free tier — 60 calls/min) ──────────────────────────────────
# Get key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_owm_api_key_here

# ── Razorpay Sandbox ───────────────────────────────────────────────────────────
# Get sandbox keys at: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ── Twilio (WhatsApp Sandbox) ─────────────────────────────────────────────────
# Get sandbox credentials at: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
